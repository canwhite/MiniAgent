# DeepSeek API Key（推荐，性价比高）
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=your_deepseek_key_here

# 或者使用 Anthropic Claude API
# 从 https://console.anthropic.com/ 获取
# ANTHROPIC_API_KEY=your_anthropic_key_here

# 日志级别配置
# NORMAL - 只输出到控制台，不写入 monitor.log
# DEBUG - 输出到控制台并写入 monitor.log 文件
LOG_LEVEL=NORMAL

# 服务器端口
PORT=3000
